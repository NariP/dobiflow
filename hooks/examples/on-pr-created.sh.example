#!/usr/bin/env bash
# dobiflow PR 생성 훅 — 예시
#
# 사용법: `.example` 빼고 아래 둘 중 한 곳에 복사 + chmod +x
#   전역    : ~/.dobiflow/hooks/on-pr-created.sh
#   프로젝트: <repo>/.claude/dobiflow-hooks/on-pr-created.sh
#
# dobiflow가 gh pr create를 실행하면 자동 호출된다. 환경변수:
#   DOBIFLOW_EVENT   = "pr-created"
#   DOBIFLOW_URL     = 생성된 PR 전체 URL
#   DOBIFLOW_COMMAND = 실행된 gh 명령 전문
#   DOBIFLOW_CWD     = 작업 디렉토리

set -euo pipefail

# --- 예시: 로그 적재 ---
echo "$(date '+%F %T')  PR     $DOBIFLOW_URL" >> "$HOME/.dobiflow/log.txt"

# --- 예시: 텔레그램 알림 ---
# curl -s "https://api.telegram.org/bot${TG_BOT_TOKEN}/sendMessage" \
#   -d chat_id="${TG_CHAT_ID}" \
#   -d text="🔀 PR 생성: ${DOBIFLOW_URL}" >/dev/null
