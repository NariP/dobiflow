{
  "description": "dobiflow 이벤트 훅 — gh issue/pr create 실행 후 사용자 정의 스크립트 트리거",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/dobiflow-hook.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
